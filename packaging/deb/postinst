#!/usr/bin/env bash
set -euo pipefail

APP_ID="clevo-control-center"
MODULE_DIR="/usr/lib/$APP_ID/module"
KERNEL_BUILD="/lib/modules/$(uname -r)/build"

if command -v update-desktop-database >/dev/null 2>&1; then
    rm -f /usr/share/applications/clevo-keyboard-led.desktop
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

if command -v make >/dev/null 2>&1 && [[ -d "$KERNEL_BUILD" ]]; then
    make -C "$MODULE_DIR" || true
    if [[ -f "$MODULE_DIR/clevo_control_center.ko" ]]; then
        install -d "/lib/modules/$(uname -r)/extra"
        modprobe -r clevo_kbd_led 2>/dev/null || true
        modprobe -r clevo_control_center 2>/dev/null || true
        install -m 0644 "$MODULE_DIR/clevo_control_center.ko" "/lib/modules/$(uname -r)/extra/clevo_control_center.ko" || true
        rm -f "/lib/modules/$(uname -r)/extra/clevo_kbd_led.ko"
        depmod -a || true
        modprobe clevo_control_center || true
    fi
else
    echo "clevo-control-center: kernel headers or make missing; module was not built automatically" >&2
fi

exit 0
