#!/usr/bin/env bash
set -euo pipefail

APP_ID="clevo-keyboard-led"
MODULE_DIR="/usr/lib/$APP_ID/module"
KERNEL_BUILD="/lib/modules/$(uname -r)/build"

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications 2>/dev/null || true
fi

if command -v make >/dev/null 2>&1 && [[ -d "$KERNEL_BUILD" ]]; then
    make -C "$MODULE_DIR" || true
    if [[ -f "$MODULE_DIR/clevo_kbd_led.ko" ]]; then
        install -d "/lib/modules/$(uname -r)/extra"
        install -m 0644 "$MODULE_DIR/clevo_kbd_led.ko" "/lib/modules/$(uname -r)/extra/clevo_kbd_led.ko" || true
        depmod -a || true
        modprobe clevo_kbd_led || true
    fi
else
    echo "clevo-keyboard-led: kernel headers or make missing; module was not built automatically" >&2
fi

exit 0
